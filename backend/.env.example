# Frontend (Vercel) - set in Vercel project dashboard
NEXT_PUBLIC_API_URL=https://boulotman-api.onrender.com

# Backend (Render) - set in Render dashboard
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=<generate-a-long-random-string>
ALLOWED_HOSTS=.onrender.com,boulotman-api.onrender.com
CORS_ALLOWED_ORIGINS=https://boulotman.vercel.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
REDIS_URL=<leave-empty-or-upstash-redis-url>
SUPABASE_URL=https://sxmjwjuwfsvjjqcldziw.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-key>
SUPABASE_STORAGE_BUCKET=boulotman
JWT_ACCESS_LIFETIME_MINUTES=1440
JWT_REFRESH_LIFETIME_DAYS=30
